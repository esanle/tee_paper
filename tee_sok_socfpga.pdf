pportunities for researchers and developers.","publicationYear":"2025","pdfPath":"/iel8/11039314/11039328/11039468.pdf","publicationDate":"09 May 2025","publicationTitle":"2025 Intermountain Engineering, Technology and Computing (IETC)","pdfUrl":"/stamp/stamp.jsp?tp=&arnumber=11039468","startPage":"1","endPage":"6","displayPublicationTitle":"2025 Intermountain Engineering, Technology and Computing (IETC)","formulaStrippedArticleTitle":"SoK: Trusted Execution in SoC-FPGAs","isGetAddressInfoCaptured":false,"isMarketingOptIn":false,"pubTopics":[{"name":"Aerospace"},{"name":"Bioengineering"},{"name":"Communication, Networking and Broadcast Technologies"},{"name":"Components, Circuits, Devices and Systems"},{"name":"Computing and Processing"},{"name":"Engineered Materials, Dielectrics and Plasmas"},{"name":"Engineering Profession"},{"name":"Fields, Waves and Electromagnetics"},{"name":"General Topics for Engineers"},{"name":"Geoscience"},{"name":"Photonics and Electrooptics"},{"name":"Power, Energy and Industry Applications"},{"name":"Robotics and Control Systems"},{"name":"Signal Processing and Analysis"},{"name":"Transportation"}],"publisher":"IEEE","displayDocTitle":"SoK: Trusted Execution in SoC-FPGAs","isLatestStandard":false,"htmlLink":"/document/11039468/","isTranslation":false,"isGiveaway":false,"isOUP":false,"isSMPTE":false,"isSAE":false,"isNow":false,"isDegruyter":false,"isCustomDenial":false,"htmlAbstractLink":"/document/11039468/","hasStandardVersions":false,"persistentLink":"https://ieeexplore.ieee.org/servlet/opac?punumber=11039314","isFreeDocument":false,"isOnlineOnly":false,"isSpringer":false,"isStandard":false,"isTutorial":false,"isEphemera":false,"isConference":true,"isPromo":false,"isBookWithoutChapters":false,"isChapter":false,"isDynamicHtml":true,"isJournal":false,"isEarlyAccess":false,"isOpenAccess":false,"isProduct":false,"isBook":false,"xploreDocumentType":"Conference Publication","startPage":"1","fundingAgencies":{"fundingAgency":[{"fundingId":"10.13039/100008287","fundingName":"Science and Technology Directorate"}]},"articleCopyRight":"2025 IEEE","openAccessFlag":"F","insertDate":"20 June 2025","ephemeraFlag":"false","title":"SoK: Trusted Execution in SoC-FPGAs","confLoc":"Orem, UT, USA","html_flag":"false","ml_html_flag":"true","sourcePdf":"1571118070.pdf","displayPublicationDate":"09-10 May 2025","mlTime":"PT0.044454S","xplore-pub-id":"11039314","pdfPath":"/iel8/11039314/11039328/11039468.pdf","isNumber":"11039328","rightsLinkFlag":"1","contentType":"conferences","publicationDate":"09 May 2025","publicationNumber":"11039314","citationCount":"1","xplore-issue":"11039328","articleId":"11039468","publicationTitle":"2025 Intermountain Engineering, Technology and Computing (IETC)","sections":{"abstract":"true","authors":"true","disclaimer":"false","figures":"true","multimedia":"false","references":"true","citedby":"true","keywords":"true","definitions":"false","algorithm":"false","dataset":"false","cadmore":"false","footnotes":"false","relatedContent":"false","metrics":"true"},"contentTypeDisplay":"Conferences","referenceCount":40,"publicationYear":"2025","subType":"IEEE Conference","_value":"IEEE","lastupdate":"2026-03-28","mediaPath":"/mediastore/IEEE/content/media/11039314/11039328/11039468","endPage":"6","displayPublicationTitle":"2025 Intermountain Engineering, Technology and Computing (IETC)","doi":"10.1109/IETC64455.2025.11039468"};








